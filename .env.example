# reMark Bridge — environment variables
#
# Copy this file to `.env` and fill in the values you actually use.
# Anything left blank is simply not exported into the containers.

# --- Core API keys ----------------------------------------------------------
# Anthropic is required for the note-processing pipeline (actions, tagger,
# summarizer). Any Claude-capable key works.
ANTHROPIC_API_KEY=

# Optional fallback OCR backends. Only set what you actually plan to use.
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# --- Microsoft Graph (Todo, Calendar, OneNote, Teams) -----------------------
# The MSAL client_id and tenant live in config.yaml (microsoft.client_id /
# microsoft.tenant), not in environment variables.

# --- Notion -----------------------------------------------------------------
# Integration token from https://www.notion.so/my-integrations. Only read
# when notion.enabled is true in config.yaml.
NOTION_TOKEN=

# --- Container image --------------------------------------------------------
# Tag of the GHCR image docker compose should pull. Leave as `latest` for
# rolling updates or pin to a specific release, e.g. REMARK_IMAGE_TAG=0.4.0.
REMARK_IMAGE_TAG=latest

# --- Web dashboard ----------------------------------------------------------
# Port the host should expose (container still listens on 8000 internally).
REMARK_WEB_PORT=8000

# HTTP Basic auth, the dashboard URL, and VAPID keys all live in
# config.yaml (under the `web:` block). Generate a VAPID pair once with:
#   docker compose run --rm web remark-bridge vapid-keys

# --- Logging ----------------------------------------------------------------
# "json" emits structured logs suited for Loki/journald. "text" is the
# default human-readable form.
REMARK_LOG_FORMAT=json

# --- Config path ------------------------------------------------------------
# Where inside the container the sync + web services look for config.yaml.
# The matching Docker mount is ./config:/config, so config/config.yaml on
# the host is /config/config.yaml inside the container.
REMARK_CONFIG=/config/config.yaml
